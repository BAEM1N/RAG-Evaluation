# 대형 로그
results/*.log
results/**/*.log
*.log

# 시스템/IDE
.DS_Store
.idea/
.vscode/

# 환경변수
.env
.env.local

# Local-only notes (planning, drafts)
_internal/

# Result file backups (local recovery only)
_backups/
results/**/_backups/
results/**/.bak_*
results/**/.backup_*

# Archived old result snapshots (kept locally, not pushed)
results/_archive/

# Large raw batch files (>50MB, kept in local _backups)
*_raw_openai_*.jsonl
*q4_openai_gpt-*.jsonl

# Cartesian gen/judge raw outputs (576K text files, ~100MB)
results/cartesian/gen/
results/cartesian/judge/

