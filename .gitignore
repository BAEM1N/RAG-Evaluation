__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# PDF 원본 (allganize 데이터셋 — 라이선스 확인 필요)
data/pdfs/

# 임베딩 캐시 (재현 가능, 용량 큼)
data/retrieval_cache/

# 외부 포크 레퍼런스 (별도 레포 원본 참조)
